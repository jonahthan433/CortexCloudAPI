# Environment Settings
ENV=development
PORT=8000
HOST=127.0.0.1

# Security (JWT Session Signature Key)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=cortexcloud-secret-jwt-signature-key-change-in-prod

# Database Configurations
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cortexcloud
REDIS_URL=redis://localhost:6379/0

# Upstream Provider API Keys
# Populate keys for the providers you want to route completions to:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# x402 Payment Gateway Configuration
# Enable crypto payments via the x402 protocol (USDC on Base)
X402_ENABLED=true
WALLET_ADDRESS=0xYourBaseWalletAddress
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
# For mainnet: X402_NETWORK=eip155:8453
